[resource]
default_font = ExtResource("1_w95fa")
default_font_size = 12

; --- Panel base ---
Panel/styles/panel = SubResource("SB_RaisedOuter")

; --- Button base ---
Button/styles/normal = SubResource("SB_RaisedNormal")
Button/styles/hover = SubResource("SB_RaisedNormal")
Button/styles/pressed = SubResource("SB_RaisedPressed")
Button/styles/focus = SubResource("SB_Focus")
Button/colors/font_color = Color(0, 0, 0, 1)
Button/font_sizes/font_size = 12

; --- Label base ---
Label/colors/font_color = Color(0, 0, 0, 1)
Label/font_sizes/font_size = 12

; --- Type variation: TitleBar (extends Panel) ---
TitleBar/base_type = &"Panel"
TitleBar/styles/panel = SubResource("SB_TitleBar")

; --- Type variation: Tile (extends Panel) ---
Tile/base_type = &"Panel"
Tile/styles/panel = SubResource("SB_Tile")

; --- Type variation: BoardCell (extends Panel) ---
BoardCell/base_type = &"Panel"
BoardCell/styles/panel = SubResource("SB_Sunken")

; --- Type variation: ScoreNeon (extends Label) ---
ScoreNeon/base_type = &"Label"
ScoreNeon/colors/font_color = Color(0, 1, 0, 1)
ScoreNeon/colors/font_outline_color = Color(0, 0, 0.5019, 1)
ScoreNeon/constants/outline_size = 2
ScoreNeon/font_sizes/font_size = 22