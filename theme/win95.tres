border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(1, 1, 1, 1)              ; aproximação: brilho. Para a sombra preta na base, prefira StyleBoxTexture 9-slice.
anti_aliasing = false

